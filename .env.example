# Admin login password (used by /login)
ADMIN_PASSWORD=change-me

# Firebase Admin service account, as a single-line JSON string.
# Local dev can instead use a serviceAccountKey.json file at the project root.
# On Vercel, paste the full service account JSON here.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"sift-d1cf4", ... }
